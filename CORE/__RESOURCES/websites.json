        "sitemap_manual": null,
        "jsonld": true,
        "selectors": {
            "ean": {"tag": "div", "class": "text-primary", "split": "EAN"},
            "mpn": {"tag": "div", "class": "text-primary", "split": "ARTICLE"},
            "brand": {"tag": "span", "class": "brand-title"},
            "article": {"tag": "span", "attr": {"data-ui-id": "page-title-wrapper"}},
            "price": {"tag": "meta", "itemprop": "price", "use_attr": "content"}
        },
        "vat_rate": 1.20
    }
