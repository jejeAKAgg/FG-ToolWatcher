        "jsonld": true,
        "selectors": {
            "ean": {"tag": "li", "text_contains": "EAN:", "replace": "EAN:"},
            "mpn": {"tag": "li", "id": "supplier_reference_value", "replace": "NUMÉRO D'ARTICLE DU FOURNISSEUR:"},
            "brand": {"tag": "li", "class": "product-manufacturer", "child_tag": "a"},
            "article": {"tag": "h1", "id": "product_name_value", "replace_duplicate": true},
